{
  "name": "voyager",
  "description": "A progressive webapp Lemmy client",
  "private": true,
  "version": "2.46.1",
  "type": "module",
  "packageManager": "pnpm@10.33.4+sha512.1c67b3b359b2d408119ba1ed289f34b8fc3c6873412bec6fd264fbdc82489e510fcbecb9ce9d22dae7f3b76269d8441046014bdca53b9979cd7a561ad631b800",
  "scripts": {
    "dev": "vite",
    "ionic:build:before": "./scripts/prebuild.sh",
    "build": "pnpm ionic:build:before && vite build",
    "postinstall": "cap telemetry off && ionic config set -g telemetry false",
    "preview": "vite preview",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:generatecsstypes": "tcm src",
    "test:typecheck": "tsc",
    "lint": "eslint src --max-warnings=0",
    "lint:formatting": "prettier --check .",
    "generate:splash:dark": "pwa-asset-generator --type png --index index.html --dark-mode --splash-only --path-override '/splash' public/splash.html public/splash/ && prettier -w index.html",
    "generate:splash:light": "pwa-asset-generator --type png --index index.html --splash-only --path-override '/splash' public/splash.html public/splash/ && prettier -w index.html",
    "generate:splash": "pnpm generate:splash:dark && pnpm generate:splash:light",
    "capacitor:copy:before": "rm -rf $CAPACITOR_WEB_DIR/splash && rm -rf $CAPACITOR_WEB_DIR/screenshots",
    "upgrade:packageManager": "corepack use pnpm@latest",
    "release": "./scripts/prerelease.sh",
    "script:update-instance-rankings": "node scripts/update_instance_rankings.js && prettier --write src/features/auth/login/data/categories.json"
  },
  "imports": {
    "#/*": "./src/*"
  },
  "dependencies": {
    "@aeharding/remark-lemmy-spoiler": "^2.0.0",
    "@aeharding/remark-lemmy-supersub": "^1.0.0",
    "@capacitor-community/app-icon": "^7.0.0",
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.1",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/network": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@github/markdown-toolbar-element": "^2.2.3",
    "@ionic/core": "npm:voyager-ionic-core@8.8.6",
    "@ionic/react": "8.8.6",
    "@ionic/react-router": "8.8.6",
    "@mantine/hooks": "^9.1.1",
    "@reduxjs/toolkit": "^2.11.2",
    "capacitor-android-nav-mode": "^3.0.0",
    "capacitor-application-context": "^3.0.0",
    "capacitor-biometric-lock": "^3.0.0",
    "capacitor-clear-cache": "^3.0.0",
    "capacitor-launch-native": "^3.0.0",
    "capacitor-reader": "^2.0.0",
    "capacitor-share-safari": "^1.0.0",
    "capacitor-stash-media": "^4.0.0",
    "capacitor-tips": "^3.0.0",
    "colorjs.io": "^0.6.1",
    "compare-versions": "^6.1.1",
    "date-fns": "^4.1.0",
    "dexie": "^4.4.2",
    "dexie-export-import": "^4.4.0",
    "es-toolkit": "^1.46.1",
    "history": "^4.10.1",
    "immer": "^11.1.7",
    "ionicons": "^8.0.13",
    "mdast-util-gfm-autolink-literal-lemmy": "^3.1.0",
    "mdast-util-gfm-strikethrough": "^2.0.0",
    "mdast-util-gfm-table": "^2.0.0",
    "mdast-util-lemmy-supersub": "^1.0.1",
    "micromark-extension-gfm-strikethrough": "^2.1.0",
    "micromark-extension-gfm-table": "^2.1.1",
    "micromark-util-combine-extensions": "^2.0.1",
    "modern-screenshot": "^4.7.0",
    "motion": "^12.38.0",
    "photoswipe": "^5.4.4",
    "react": "^19.2.6",
    "react-animate-height": "^3.2.4",
    "react-dom": "^19.2.6",
    "react-error-boundary": "^6.1.1",
    "react-intersection-observer": "^10.0.3",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.2.0",
    "react-reverse-portal": "^2.3.0",
    "react-router": "^5.3.4",
    "react-router-dom": "^5.3.4",
    "react-textarea-autosize": "^8.5.9",
    "react-transition-state": "^2.3.3",
    "rehype-highlight": "^7.0.2",
    "rehype-parse": "^9.0.1",
    "rehype-remark": "^10.0.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "threadiverse": "link:../threadiverse",
