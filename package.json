    "postcss": "^8.5.16",
    "prettier": "^3.9.1",
    "pwa-asset-generator": "^8.1.5",
    "release-it": "^20.2.1",
    "typed-css-modules": "^0.9.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-svgr": "^5.2.0",
    "vitest": "^4.1.9"
  }
}
