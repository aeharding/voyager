{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Voyager",
  "mainBinaryName": "voyager",
  "version": "../package.json",
  "identifier": "app.vger.Voyager",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Voyager",
        "width": 1200,
        "height": 800,
        "minWidth": 360,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage"],
    "category": "SocialNetworking",
    "shortDescription": "Voyager for Lemmy and PieFed",
    "longDescription": "A mobile-first client for Lemmy and PieFed, now on your desktop.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  }
}
